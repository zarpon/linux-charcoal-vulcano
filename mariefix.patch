diff --git a/mm/lru_marie/state.c b/mm/lru_marie/state.c
--- a/mm/lru_marie/state.c
+++ b/mm/lru_marie/state.c
@@ -2129,14 +2129,14 @@ static inline bool lru_marie_activate_folio(struct folio *folio)
  {
 	/*
 	 * Publish PG_lru and update counters in line, synchronously under
 	 * the caller's lru_lock. PG_active is cleared in the same atomic
 	 * mask write (was already cleared above for was_active==true; the
 	 * mask keeps the invariant for the defensive case where another
 	 * path set it between then and now).
 	 */
-	set_mask_bits(&folio->flags.f, BIT(PG_active), BIT(PG_lru));
+	set_mask_bits(&folio->flags, BIT(PG_active), BIT(PG_lru));
 	inst_lru = folio_lru_list(folio);
 
 	marie_pc_add(&mlv->types[type].nr_pages, nr);
 	marie_pc_add(&marie_nr_folios, 1);
 	marie_update_lru_size(mlv->lruvec, inst_lru, zone, nr);
