From 64a511323d22f510cb806b987ac7de7b188d7913 Mon Sep 17 00:00:00 2001
From: Codex Validation <noreply@localhost>
Date: Thu, 23 Jul 2026 13:16:21 -0500
Subject: [PATCH] sched: port 0002 sched-ext coexistence fix to Valve 6.16.12

---
 include/linux/sched/bore.h |  1 +
 kernel/sched/fair.c        | 13 +++++++++++++
 2 files changed, 14 insertions(+)

diff --git a/include/linux/sched/bore.h b/include/linux/sched/bore.h
index 76afe1d25..071e56aaf 100644
--- a/include/linux/sched/bore.h
+++ b/include/linux/sched/bore.h
@@ -42,5 +42,6 @@ extern int  sched_burst_protect_slice_lv_update_handler(const struct ctl_table *
 
 extern void reweight_entity(
 	struct cfs_rq *cfs_rq, struct sched_entity *se, unsigned long weight);
+extern void reweight_task(struct task_struct *p, int prio);
 
 #endif /* _KERNEL_SCHED_BORE_H */
diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index ea3129d11..ce179c706 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -13879,3 +13879,16 @@ __init void init_sched_fair_class(void)
 #endif /* SMP */
 
 }
+
+#ifdef CONFIG_SCHED_BORE
+void reweight_task(struct task_struct *p, int prio)
+{
+	struct sched_entity *se = &p->se;
+	struct cfs_rq *cfs_rq = cfs_rq_of(se);
+	struct load_weight *load = &se->load;
+	unsigned long weight = scale_load(sched_prio_to_weight[prio]);
+
+	reweight_entity(cfs_rq, se, weight);
+	load->inv_weight = sched_prio_to_wmult[prio];
+}
+#endif /* CONFIG_SCHED_BORE */
-- 
