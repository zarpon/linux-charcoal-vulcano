+/*
+ * Global folio counter, lives in mm/lru_marie/core.c for stats_show;
+ * the install/evict helpers in state.c percpu_counter_add it during
+ * Marie's TRACKED 0<->1 transitions.
+ */
+extern struct percpu_counter marie_nr_folios;
+
+/*
+ * marie_pc_add - Marie-private percpu_counter add that elides the
+ * standard preempt_disable / preempt_enable bracket.
+ *
+ * percpu_counter_add_batch() disables preempt internally to protect
+ * the per-CPU diff's read-modify-write against task migration. Every
+ * Marie caller of this routine -- install_local, install_locked,
+ * install_at_gen, evict_locked, reparent_locked, the lru_marie_del_folio
+ * dispatcher, lru_marie_split_folio, plus the fill / drain paths --
+ * already holds lruvec->lru_lock via spin_lock_irqsave (or a stricter
+ * outer lock), which has both preempt AND IRQ disabled for the entire
+ * critical section. The extra preempt_disable inside percpu_counter
+ * is therefore pure overhead. Under 16-thread memhog it shows up in
+ * perf as ~4 % of total CPU spent in preempt_count_add +
+ * check_preemption_disabled. Use the underlying primitives directly.
+ *
+ * Lock contract: caller MUST be in preempt-off context (typically via
+ * spin_lock_irqsave on lru_lock). DEBUG_PREEMPT builds enforce this
+ * via __this_cpu_*'s built-in check.
+ *
+ * Flush-path lock: the original percpu_counter_add_batch uses
+ * raw_spin_lock_irqsave on fbc->lock when the per-CPU diff exceeds
+ * the batch threshold. Since IRQs are already disabled here we drop
+ * to plain raw_spin_lock -- one fewer FLAGS load/store per flush.
+ */
+static inline void marie_pc_add(struct percpu_counter *fbc, s64 amount)
+{
+	s64 count;
+
+	count = __this_cpu_read(*fbc->counters) + amount;
+	if (unlikely(abs(count) >= percpu_counter_batch)) {
+		raw_spin_lock(&fbc->lock);
+		fbc->count += count;
+		__this_cpu_sub(*fbc->counters, count - amount);
+		raw_spin_unlock(&fbc->lock);
+	} else {
+		__this_cpu_write(*fbc->counters, count);
+	}
+}
